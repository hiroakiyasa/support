---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>https://hiroakiyasa.github.io/support/</loc>
    <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>
{% for page in site.pages %}
  {% unless page.sitemap_exclude == 'y' %}
  <url>
    <loc>https://hiroakiyasa.github.io/support{{ page.url | remove: 'index.html' }}</loc>
    <lastmod>{{ page.date | default: site.time | date_to_xmlschema }}</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>
  {% endunless %}
{% endfor %}
</urlset>